# ── Backend (server/.env or Render dashboard) ──────────────────────────────
# PostgreSQL connection string from Render (Internal Database URL)
DATABASE_URL=postgresql://user:password@host:5432/miysara_store

# JWT secret — any long random string (Render can auto-generate this)
JWT_SECRET=change-me-to-a-long-random-string

# ── Frontend (Vite build) ───────────────────────────────────────────────────
# No frontend env vars needed — the frontend talks to /api which is served
# by the same Express process in production.
